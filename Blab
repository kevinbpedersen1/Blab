h+=’<div style="font-size:11px;letter-spacing:0.2em;color:#666;font-weight:600;margin-bottom:20px">YOUR MAXES</div>’;
var fields=[[“bench1rm”,“BENCH PRESS 1RM (kg)”,“True max — estimate LOW”],[“squat1rm”,“SQUAT/DEADLIFT 1RM (kg)”,“Choose squat or deadlift. Stick with it.”],[“chinMax”,“CHIN-UP MAX REPS”,“Consecutive reps, one set. 0 if none.”]];
fields.forEach(function(f){
h+=’<div style="margin-bottom:24px"><label style="font-size:11px;letter-spacing:0.15em;color:#999;font-weight:500;display:block;margin-bottom:6px">’+f[1]+’</label>’;
h+=’<input type="number" value="'+E(SET[f[0]])+'" oninput="uSet(\''+f[0]+'\',this.value)" style="background:#111;border:1px solid rgba(255,255,255,0.12);border-radius:2px;color:#fff;padding:12px 16px;width:100%;font-size:20px;font-weight:700;font-family:inherit;box-sizing:border-box;outline:none" placeholder="0">’;
h+=’<div style="font-size:11px;color:#555;margin-top:4px">’+f[2]+’</div></div>’;
});
// Rules
h+=’<div style="margin-top:32px;border-top:1px solid rgba(255,255,255,0.08);padding-top:24px">’;
h+=’<div style="font-size:11px;letter-spacing:0.2em;color:#666;font-weight:600;margin-bottom:16px">PROGRAM RULES</div>’;
var rules=[“Max-effort rest: 3\u20135 min between work sets”,“Accessory rest: 1\u20132 min unless noted”,“Supersets (3a/3b): A\u2192B back-to-back, then rest”,”\u2018+ AMRAP\u2019 = Do as many reps as possible. RECORD.”,“Power Clean added to Day 2 as a primer”,“Warm-up: Simple 6 (upper) / Agile 8 (lower) \u2014 NEVER skip”];
rules.forEach(function(r,i){
h+=’<div style="font-size:13px;color:#888;line-height:1.6;margin-bottom:6px"><span style="color:#444;margin-right:8px">’+String(i+1).padStart(2,“0”)+’</span>’+r+’</div>’;
});
h+=’</div>’;
// Backup
h+=’<div style="margin-top:32px;border-top:1px solid rgba(255,255,255,0.08);padding-top:24px">’;
h+=’<div style="font-size:11px;letter-spacing:0.2em;color:#666;font-weight:600;margin-bottom:16px">DATA BACKUP</div>’;
h+=’<div style="display:flex;gap:12px">’;
h+=’<button onclick="doExport()" style="flex:1;background:#fff;color:#000;border:none;border-radius:2px;padding:12px 0;font-size:11px;font-weight:700;letter-spacing:0.15em;cursor:pointer">EXPORT JSON</button>’;
h+=’<button onclick="doImport()" style="flex:1;background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.2);border-radius:2px;padding:12px 0;font-size:11px;font-weight:700;letter-spacing:0.15em;cursor:pointer">IMPORT JSON</button>’;
h+=’</div>’;
h+=’<div style="font-size:10px;color:#444;margin-top:8px">Eksporter regelm\u00e6ssigt som backup.</div>’;
h+=’</div></div>’;
}

// === PROGRAM ===
if(v===“program”){
h+=’<div>’;
// Week scroll
h+=’<div class="ws">’;
PROGRAM.weeks.forEach(function(w,i){
var comp=gC(w.week),sel=S.wi===i;
h+=’<button onclick="S.wi='+i+';S.di=0;R()" style="background:'+(sel?'#fff':w.deload?'rgba(255,180,0,0.08)':'#111')+';color:'+(sel?'#000':w.deload?'#aa8800':'#666')+';border:'+(sel?'none':'1px solid rgba(255,255,255,0.08)')+';border-radius:2px;padding:8px 10px;font-size:10px;font-weight:700;letter-spacing:0.1em;cursor:pointer;white-space:nowrap;min-width:40px;position:relative">’+w.week;
if(comp>0)h+=’<div style="position:absolute;bottom:-2px;left:50%;transform:translateX(-50%);width:'+Math.max(4,comp/100*30)+'px;height:2px;background:'+(comp===100?'#4ade80':'#fff')+';border-radius:1px"></div>’;
h+=’</button>’;
});
h+=’</div>’;
// Phase
h+=’<div style="padding:20px 20px 0"><div style="font-size:11px;letter-spacing:0.2em;color:'+(cw.deload?'#aa8800':'#555')+';font-weight:600">’+E(cw.phase)+’</div>’;
h+=’<div style="font-size:22px;font-weight:800;margin-top:2px">’+E(cw.label)+’</div></div>’;
// Day tabs
h+=’<div style="display:flex;gap:8px;padding:16px 20px">’;
cw.days.forEach(function(d,i){
var sel=S.di===i;
h+=’<button onclick="S.di='+i+';R()" style="flex:1;background:'+(sel?'#fff':'transparent')+';color:'+(sel?'#000':'#666')+';border:'+(sel?'none':'1px solid rgba(255,255,255,0.12)')+';border-radius:2px;padding:10px 0;font-size:11px;font-weight:700;letter-spacing:0.1em;cursor:pointer">DAY ‘+d.day+’</button>’;
});
h+=’</div>’;
// Day content
if(cd){
h+=’<div style="padding:0 20px">’;
h+=’<div style="font-size:16px;font-weight:800;letter-spacing:0.05em">’+E(cd.title)+’</div>’;
h+=’<div style="font-size:11px;color:#555;margin-top:4px;letter-spacing:0.1em">WARM-UP // ‘+E(cd.warmup)+’</div>’;
cd.sections.forEach(function(sec,si){
var sc=sec.name.indexOf(“FINISHER”)>-1?”#e55”:sec.name.indexOf(“POWER”)>-1?”#f0a030”:”#666”;
h+=’<div class="sa" style="margin-top:24px;animation-delay:'+si*0.05+'s">’;
h+=’<div style="font-size:10px;letter-spacing:0.2em;color:'+sc+';font-weight:700;padding-bottom:8px;border-bottom:1px solid rgba(255,255,255,0.06)">’+E(sec.name)+’</div>’;
sec.exercises.forEach(function(ex){
var lg=LOG[ex.id]||{},tw=cW(ex.pct,cd.day),prev=gPrev(ex.id);
h+=’<div style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04);'+(lg.done?'opacity:0.45':'')+'">’;
// Name row
h+=’<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px"><div style="flex:1"><div style="font-size:13px;font-weight:'+(ex.amrap?700:500)+';color:'+(ex.amrap?'#fff':'#ccc')+';line-height:1.3">’+E(ex.name);
if(ex.amrap)h+=’<span style="color:#e55;font-size:10px;margin-left:6px;font-weight:800">AMRAP</span>’;
h+=’</div>’;
if(ex.note)h+=’<div style="font-size:10px;color:#555;margin-top:2px">’+E(ex.note)+’</div>’;
h+=’</div>’;
h+=’<button onclick="uLog(\''+ex.id+'\',\'done\','+(lg.done?'false':'true')+')" style="background:'+(lg.done?'#fff':'transparent')+';border:'+(lg.done?'none':'1px solid rgba(255,255,255,0.2)')+';border-radius:2px;width:24px;height:24px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;color:#000;flex-shrink:0">’+(lg.done?’\u2713’:’’)+’</button></div>’;
// Prescription
h+=’<div style="display:flex;gap:16px;margin-top:8px;font-size:11px;color:#666"><span>’+E(ex.sets)+’ \u00d7 ‘+E(ex.reps)+’</span>’;
if(ex.pct&&ex.pct!==”—”)h+=’<span style="color:#888">’+E(ex.pct)+’</span>’;
if(tw!==”—”&&tw!==“SET_1RM”)h+=’<span style="color:#fff;font-weight:600">’+tw+’ kg</span>’;
if(tw===“SET_1RM”)h+=’<span style="color:#e55;font-size:10px">Set 1RM in Setup</span>’;
h+=’</div>’;
// Prev week
if(prev){
h+=’<div style="margin-top:6px;padding:6px 10px;background:rgba(255,255,255,0.03);border-left:2px solid rgba(255,255,255,0.15);border-radius:0 2px 2px 0;display:flex;align-items:center;gap:10px">’;
h+=’<span style="font-size:9px;letter-spacing:0.15em;color:#555;font-weight:700">W’+prev.week+’</span>’;
h+=’<span style="font-size:12px;color:#888">’;
if(prev.weight)h+=’<span style="color:#aaa;font-weight:600">’+E(prev.weight)+‘kg</span>’;
if(prev.weight&&prev.reps)h+=’<span style="color:#555"> \u00d7 </span>’;
if(prev.reps)h+=’<span style="color:#aaa;font-weight:600">’+E(prev.reps)+’ reps</span>’;
h+=’</span></div>’;
}
// Inputs
h+=’<div style="display:flex;gap:8px;margin-top:8px">’;
h+=’<input type="number" placeholder="'+(prev&&prev.weight?prev.weight:'Weight')+'" value="'+E(lg.weight||'')+'" oninput="uLog(\''+ex.id+'\',\'weight\',this.value)" style="background:#111;border:1px solid rgba(255,255,255,0.08);border-radius:2px;color:#fff;padding:8px 10px;font-size:13px;font-weight:600;width:80px;font-family:inherit;outline:none;box-sizing:border-box">’;
h+=’<input placeholder="'+(prev&&prev.reps?prev.reps:(ex.timed?'Time':'Reps'))+'" value="'+E(lg.reps||'')+'" oninput="uLog(\''+ex.id+'\',\'reps\',this.value)" style="background:#111;border:1px solid rgba(255,255,255,0.08);border-radius:2px;color:#fff;padding:8px 10px;font-size:13px;font-weight:600;width:80px;font-family:inherit;outline:none;box-sizing:border-box">’;
h+=’<input placeholder="Notes" value="'+E(lg.notes||'')+'" oninput="uLog(\''+ex.id+'\',\'notes\',this.value)" style="background:#111;border:1px solid rgba(255,255,255,0.08);border-radius:2px;color:#fff;padding:8px 10px;font-size:12px;font-weight:400;flex:1;font-family:inherit;outline:none;box-sizing:border-box">’;
h+=’</div></div>’;
});
h+=’</div>’;
});
h+=’</div>’;
}
h+=’</div>’;
}

// === PROGRESS ===
if(v===“progress”){
h+=’<div style="padding:32px 20px">’;
h+=’<div style="font-size:11px;letter-spacing:0.2em;color:#666;font-weight:600;margin-bottom:20px">WEEKLY COMPLETION</div>’;
PROGRAM.weeks.forEach(function(w){
var comp=gC(w.week);
h+=’<div style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;margin-bottom:4px">’;
h+=’<span style="font-size:12px;font-weight:600;color:'+(w.deload?'#aa8800':'#999')+';letter-spacing:0.1em">’+E(w.label)+(w.deload?’ — DELOAD’:’’)+’</span>’;
h+=’<span style="font-size:12px;font-weight:700;color:'+(comp===100?'#4ade80':'#666')+'">’+comp+’%</span></div>’;
h+=’<div style="background:#111;border-radius:1px;height:4px;overflow:hidden"><div style="width:'+comp+'%;height:100%;border-radius:1px;background:'+(comp===100?'#4ade80':comp>0?'#fff':'transparent')+'"></div></div></div>’;
});
// AMRAP
h+=’<div style="margin-top:40px;border-top:1px solid rgba(255,255,255,0.08);padding-top:24px">’;
h+=’<div style="font-size:11px;letter-spacing:0.2em;color:#666;font-weight:600;margin-bottom:16px">AMRAP RECORDS</div>’;
var ac=0;
PROGRAM.weeks.forEach(function(w){w.days.forEach(function(d){d.sections.forEach(function(s){s.exercises.forEach(function(e){
if(e.amrap&&LOG[e.id]&&LOG[e.id].reps){ac++;var l=LOG[e.id];
h+=’<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:12px">’;
h+=’<span style="color:#555;font-weight:600;min-width:48px">W’+w.week+‘D’+d.day+’</span>’;
h+=’<span style="color:#ccc;flex:1">’+E(e.name)+’</span>’;
h+=’<span style="color:#fff;font-weight:700">’+(l.weight?l.weight+‘kg \u00d7 ‘:’’)+l.reps+’</span></div>’;}
})})})});
if(ac===0)h+=’<div style="font-size:12px;color:#444">No AMRAP records yet.</div>’;
h+=’</div>’;
// Weight progression
h+=’<div style="margin-top:40px;border-top:1px solid rgba(255,255,255,0.08);padding-top:24px">’;
h+=’<div style="font-size:11px;letter-spacing:0.2em;color:#666;font-weight:600;margin-bottom:16px">WEIGHT PROGRESSION</div>’;
var tr={};
PROGRAM.weeks.forEach(function(w){w.days.forEach(function(d){d.sections.forEach(function(s){s.exercises.forEach(function(e){
var lg=LOG[e.id];if(!lg||!lg.weight)return;
var nn=e.name.replace(/^[\u2605\s]+/,””).replace(/\s*\u2014\s*Set\s*\d+/i,””).replace(/\s*(total.*?)/i,””).replace(/\s*(\d+\s*lb.*?)/i,””).replace(/\s*(BW.*?)/i,””).trim();
var key=“D”+d.day+”|”+nn;
if(!tr[key])tr[key]={name:nn,day:d.day,entries:[]};
tr[key].entries.push({week:w.week,weight:lg.weight});
})})})});
var groups=Object.values(tr).filter(function(g){return g.entries.length>0});
if(groups.length===0)h+=’<div style="font-size:12px;color:#444">No weights logged yet.</div>’;
else groups.forEach(function(g){
var mx=Math.max.apply(null,g.entries.map(function(e){return parseFloat(e.weight)||0}));
h+=’<div style="margin-bottom:20px"><div style="display:flex;align-items:baseline;gap:8px;margin-bottom:6px">’;
h+=’<span style="font-size:10px;color:#444;font-weight:600">D’+g.day+’</span>’;
h+=’<span style="font-size:12px;color:#ccc;font-weight:600">’+E(g.name)+’</span></div>’;
h+=’<div style="display:flex;gap:4px;align-items:flex-end;height:48px;margin-bottom:4px">’;
g.entries.forEach(function(e){
var w=parseFloat(e.weight)||0,ht=mx>0?Math.max(4,w/mx*44):4,im=w===mx&&g.entries.length>1;
h+=’<div style="display:flex;flex-direction:column;align-items:center;gap:2px;flex:1">’;
h+=’<span style="font-size:10px;color:'+(im?'#4ade80':'#888')+';font-weight:600">’+e.weight+’</span>’;
h+=’<div style="width:100%;max-width:28px;height:'+ht+'px;border-radius:2px 2px 0 0;background:'+(im?'#4ade80':'rgba(255,255,255,0.15)')+'"></div>’;
h+=’<span style="font-size:8px;color:#444;font-weight:600">W’+e.week+’</span></div>’;
});
h+=’</div><div style="border-bottom:1px solid rgba(255,255,255,0.04)"></div></div>’;
});
h+=’</div>’;
// Reset
h+=’<div style="margin-top:40px;text-align:center">’;
h+=’<button onclick="if(confirm(\'Reset all data?\')){LOG={};persist();R()}" style="background:transparent;border:1px solid rgba(255,0,0,0.2);border-radius:2px;color:#e55;padding:10px 24px;font-size:11px;font-weight:600;letter-spacing:0.15em;cursor:pointer">RESET ALL DATA</button>’;
h+=’</div></div>’;
}

h+=’<div style="text-align:center;padding:40px 20px 20px;font-size:10px;letter-spacing:0.2em;color:#333;font-weight:600">BUILT LIKE A BADASS // 12 weeks. No shortcuts.</div>’;
document.getElementById(“a”).innerHTML=h;
}
R();
</script>

