var cf=-1,idx=0;
cd.sections.forEach(function(s){s.exercises.forEach(function(e){if(e.id===exId)cf=idx;idx++})});
for(var pi=wi-1;pi>=0;pi–){
var pw=PROGRAM.weeks[pi];
var pd=pw.days.find(function(d){return d.day===cd.day});
if(!pd)continue;
var pidx=0,match=null;
pd.sections.forEach(function(s){s.exercises.forEach(function(e){if(pidx===cf)match=e;pidx++})});
if(match&&LOG[match.id]&&(LOG[match.id].weight||LOG[match.id].reps))
return{weight:LOG[match.id].weight,reps:LOG[match.id].reps,notes:LOG[match.id].notes,name:match.name,week:pw.week};
}
return null;
}
