if(!rm||isNaN(rm))return”SET_1RM”;
return(Math.round((rm*p)/2.5)*2.5).toFixed(1);
}
function gC(wk){
var wd=PROGRAM.weeks.find(function(w){return w.week===wk});
if(!wd)return 0;var t=0,d=0;
wd.days.forEach(function(dy){dy.sections.forEach(function(s){s.exercises.forEach(function(e){t++;if(LOG[e.id]&&LOG[e.id].done)d++})})});
return t>0?Math.round(d/t*100):0;
}
function gPrev(exId){
var wi=S.wi;if(wi===0)return null;
